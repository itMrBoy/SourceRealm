# ============================================================
# SourceRealm 环境变量示例(模板)
#
# 用法:复制本文件为 .env,再按需修改。
#   cp .env.example .env
# .env 已被 .gitignore 忽略,不会提交;本示例文件只作模板与文档。
# 下面所有变量都是「可选」,留空即使用注释中标注的默认值。
# ============================================================


# ---------- 服务端(packages/server) ----------
# 注意:服务端直接读取 process.env,不会自动加载本目录的 .env。
#   想让以下变量生效,任选其一:
#     1) 在启动前于 shell 中 export;或
#     2) Node 20+ 用 `node --env-file=.env ...` 启动。
#   ⚠ 推荐用「进程级」注入(方式 2),不要把 ANTHROPIC_* export 到全局 shell,
#     否则你在同一终端手动运行的 `claude` 命令也会被这些变量影响登录态。

# 本地服务监听端口(默认 4977)
PORT=4977

# 数据落盘根目录(默认启动目录下的 .sourcerealm);可指向临时目录做隔离测试
# 示例:SOURCEREALM_HOME=/tmp/source-realm-data
SOURCEREALM_HOME=

# AI 引擎选择【必填,第一判断源,系统不做任何降级】:
#   true  = 用本机 Claude Code CLI 自主进目录探索(省主控 context;需已安装 claude code)
#   false = 用 Anthropic SDK 直连(需配置下面的 ANTHROPIC_BASE_URL + ANTHROPIC_API_KEY)
# 未设置 / 取值非法,或所选模式未就绪,服务会报错提示你去配置,绝不自动切到另一模式。
SOURCEREALM_USE_CLI=

# claude 可执行文件路径(可选)。仅 SOURCEREALM_USE_CLI=true 时用到。
# 系统会自动探测常见安装位置(Windows winget / npm 全局 / macOS Homebrew / 官方 installer / PATH)。
# 仅当自动探测失败时,才需手动指定 claude 可执行文件的绝对路径。
# 示例(Windows winget):SOURCEREALM_CLAUDE_PATH=C:\Users\<你>\AppData\Local\Microsoft\WinGet\Packages\Anthropic.ClaudeCode_..._x_x\claude.exe
SOURCEREALM_CLAUDE_PATH=

# 中转/代理地址(CLI 与 SDK 两种模式共用)。⚠ 不要带 /v1 后缀,客户端会自动追加 /v1/messages。
# 留空则走 Anthropic 官方地址。
# 示例:ANTHROPIC_BASE_URL=https://your-relay.example.com
ANTHROPIC_BASE_URL=

# 中转 API Key(CLI 与 SDK 两种模式共用)。
#   - SOURCEREALM_USE_CLI=true 时:注入给 claude CLI 子进程,强制走中转(覆盖本机 OAuth 登录态)。
#   - SOURCEREALM_USE_CLI=false 时:SDK 直连鉴权用它。
ANTHROPIC_API_KEY=

# 并行生成的关卡数上限(可选,默认 3)。
#   CLI 模式 = 同时运行的 claude 子进程数;SDK 模式 = 并发 API 请求数。
#   过高易触发中转 rate limit / 本机资源压力。
SOURCEREALM_CONCURRENCY=

# 覆盖 SDK 模式使用的模型(默认 claude-opus-4-8;仅 SOURCEREALM_USE_CLI=false 时生效)
SOURCEREALM_MODEL=


# ---------- 前端(packages/web,Vite 构建时注入) ----------
# 注意:VITE_ 前缀变量由 Vite 在「构建 / dev 启动」时读取,且 Vite 默认
#   从 packages/web 目录读 .env。若希望它们生效,请把变量放到
#   packages/web/.env,或在 `pnpm build` / `pnpm dev` 前 export。
# 仅当前端与后端不同源(分离部署 / 跨端口调试)时才需要设置;
# 默认走同源 /api,无需配置。

# 前端访问的 REST API 基地址(默认同源 /api)
# 示例:VITE_SOURCEREALM_API_BASE=http://localhost:4977/api
VITE_SOURCEREALM_API_BASE=

# SSE 生成进度「订阅链接」基地址(默认复用 VITE_SOURCEREALM_API_BASE)
# 示例:VITE_SOURCEREALM_EVENTS_BASE=http://localhost:4977/api
VITE_SOURCEREALM_EVENTS_BASE=
