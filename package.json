{
  "name": "sourcerealm",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "engines": { "node": ">=18.19.0" },
  "scripts": {
    "test": "vitest run",
    "dev": "pnpm --parallel --filter @sourcerealm/web --filter @sourcerealm/server dev",
    "build": "pnpm --filter @sourcerealm/web build",
    "start": "pnpm --filter @sourcerealm/server dev"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
